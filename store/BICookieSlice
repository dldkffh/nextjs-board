const base64 = require("base-64");
let BI = [];

function makeNewBICookie(BI) {
  const lang = navigator.language.substring(0, 2);
  const prefertheme = window.matchMedia("(prefers-color-scheme: dark)")
    ? 1
    : 0;
  BI = [lang, prefertheme];
  i18n.changeLanguage(BI[0]);
  Cookies.set("BI", base64.encode(BI), { expires: 396 });
  return BI;
}

function setBICookie(BI) {  
  Cookies.set("BI", base64.encode(BI), { expires: 396 });
  return BI;
}

function getBICookie(BI) {
  BI = base64.decode(Cookies.get("BI")).split(",");
  BI[1] = JSON.parse(BI[1]);
  i18n.changeLanguage(BI[0]);
  return BI;
}

function checkBICookie(BI) {
  if (Cookies.get("BI") === undefined) {
    BI = makeNewBICookie(BI);
    return BI;
  } else {
    BI = getBICookie(BI);
    return BI;
  }
}

BI = checkBICookie(BI);

console.log(BI);
